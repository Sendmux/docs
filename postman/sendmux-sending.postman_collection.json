              ],
              "query": [],
              "variable": []
            }
          },
          "response": []
        },
        {
          "event": [],
          "name": "Send a batch of emails",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "body": {
              "mode": "raw",
