{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SendMux",
  "colors": {
    "primary": "#6a75f1",
    "light": "#5a84e9",
    "dark": "#004aad"
  },
  "favicon": "/images/favicon.ico",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index"]
          },
          {
            "group": "Sending emails",
            "pages": [
              "guides/sending-via-http",
              "guides/sending-via-smtp",
              "guides/attachments",
              "guides/idempotency"
            ]
          }
        ]
      },
      {
        "tab": "Sending API",
        "openapi": "https://smtp.sendmux.ai/api/v1/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": ["sending-api/introduction", "sending-api/errors"]
          },
          {
            "group": "Emails",
            "pages": ["POST /emails/send", "POST /emails/send/batch"]
          }
        ]
      },
      {
        "tab": "Management API",
        "openapi": "https://app.sendmux.ai/api/v1/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction", "api-reference/errors"]
          },
          {
            "group": "Providers",
            "pages": ["GET /providers", "GET /providers/stats"]
          },
          {
            "group": "Emails",
            "pages": [
              "GET /emails/metrics",
              "GET /emails/logs",
              "GET /emails/logs/{logId}"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "GET /billing/balance",
              "GET /billing/summary",
              "GET /billing/transactions"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.sendmux.ai",
          "icon": "gauge"
        },
        {
          "anchor": "Website",
          "href": "https://sendmux.ai",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://sendmux.ai"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@sendmux.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.sendmux.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sendmux",
      "github": "https://github.com/sendmux"
    }
  },
  "fonts": {
    "family": "Lato",
    "weight": 400,
    "heading": {
      "family": "Lato",
      "weight": 700
    },
    "body": {
      "family": "Lato",
      "weight": 400
    }
  },
  "description": "The intelligent email layer",
  "appearance": {
    "default": "system"
  }
}
