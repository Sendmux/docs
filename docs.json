{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Sendmux",
  "colors": {
    "primary": "#6a75f1",
    "light": "#5a84e9",
    "dark": "#004aad"
  },
  "favicon": "/images/favicon.ico",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "icon": "play",
            "pages": [
              "index",
              "guides/quickstart",
              "guides/postman-collection",
              "guides/team-limits"
            ]
          },
          {
            "group": "SDKs",
            "icon": "code",
            "pages": [
              "sdks/index",
              "sdks/typescript",
              "sdks/python",
              "sdks/go",
              "sdks/php",
              "sdks/ruby",
              "sdks/versioning-support"
            ]
          },
          {
            "group": "CLI",
            "icon": "square-terminal",
            "pages": ["cli/index"]
          },
          {
            "group": "AI integrations",
            "icon": "robot",
            "pages": ["guides/agent-skills", "guides/mcp", "guides/mcp-clients"]
          },
          {
            "group": "Teams and access",
            "icon": "users",
            "pages": [
              "guides/teams-access",
              "guides/account-settings",
              "guides/api-keys"
            ]
          },
          {
            "group": "Sending",
            "icon": "paper-plane",
            "pages": [
              "guides/sending-via-http",
              "guides/sending-via-smtp",
              "guides/sending-accounts",
              "guides/delivery-groups",
              "guides/http-provider",
              "guides/attachments",
              "guides/idempotency"
            ]
          },
          {
            "group": "Receiving",
            "icon": "inbox",
            "pages": [
              "guides/domain-management",
              "guides/mailboxes",
              "guides/domain-settings",
              "guides/mailbox-push-delivery"
            ]
          },
          {
            "group": "Monitoring",
            "icon": "chart-line",
            "pages": ["guides/dashboard-logs", "guides/deliverability"]
          },
          {
            "group": "Billing",
            "icon": "credit-card",
            "pages": ["guides/billing"]
          },
          {
            "group": "Webhooks",
            "icon": "link",
            "pages": [
              "guides/webhooks-setup",
              "guides/webhooks-verify-signatures",
              "guides/webhook-replay"
            ]
          }
        ]
      },
      {
        "tab": "Management API",
        "openapi": {
          "source": "openapi-app.json",
          "directory": "api"
        },
        "groups": [
          {
            "group": "Overview",
            "pages": ["api/introduction", "api/errors"]
          },
          {
            "group": "Domains",
            "pages": [
              "GET /domains",
              "POST /domains",
              "GET /domains/{public_id}",
              "PATCH /domains/{public_id}",
              "GET /domains/{public_id}/zone-file",
              "POST /domains/{public_id}/verify",
              "DELETE /domains/{public_id}",
              "GET /domains/{public_id}/filters",
              "PUT /domains/{public_id}/filters"
            ]
          },
          {
            "group": "Mailboxes",
            "pages": [
              "GET /mailboxes",
              "POST /mailboxes",
              "GET /mailboxes/{public_id}",
              "PATCH /mailboxes/{public_id}",
              "DELETE /mailboxes/{public_id}",
              "POST /mailboxes/{public_id}/suspend",
              "POST /mailboxes/{public_id}/resume",
              "GET /mailboxes/{public_id}/filters",
              "PUT /mailboxes/{public_id}/filters",
              "POST /mailboxes/{public_id}/keys",
              "DELETE /mailboxes/{public_id}/keys/{key_id}"
            ]
          },
          {
            "group": "Inbox logs",
            "pages": ["GET /inboxes/logs", "GET /inboxes/logs/{public_id}"]
          },
          {
            "group": "Sending accounts",
            "pages": [
              "GET /providers/stats",
              "GET /providers/limits",
              "POST /providers/limits/sending-accounts/request-increase",
              "GET /providers/shared-amazon-ses-limit-request",
              "POST /providers/shared-amazon-ses-limit-request",
              "GET /providers/usage",
              "GET /providers",
              "POST /providers",
              "GET /providers/{public_id}",
              "PATCH /providers/{public_id}",
              "DELETE /providers/{public_id}",
              "POST /providers/{public_id}/activate",
              "POST /providers/{public_id}/deactivate",
              "POST /providers/{public_id}/test"
            ]
          },
          {
            "group": "Emails",
            "pages": [
              "GET /emails/metrics",
              "GET /emails/logs",
              "GET /emails/logs/{public_id}"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "GET /billing/balance",
              "GET /billing/summary",
              "GET /billing/transactions"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "GET /webhooks",
              "POST /webhooks",
              "GET /webhooks/{public_id}",
              "GET /webhooks/{public_id}/deliveries",
              "GET /webhooks/{public_id}/deliveries/{delivery_id}/payload",
              "PATCH /webhooks/{public_id}",
              "DELETE /webhooks/{public_id}",
              "POST /webhooks/{public_id}/rotate-secret",
              "POST /webhooks/{public_id}/test"
            ]
          }
        ]
      },
      {
        "tab": "Mailbox API",
        "openapi": {
          "source": "openapi-app.json",
          "directory": "api"
        },
        "groups": [
          {
            "group": "Overview",
            "pages": ["mailbox-api/introduction", "mailbox-api/errors"]
          },
          {
            "group": "Mailbox",
            "pages": [
              "GET /mailbox/mailboxes",
              "GET /mailbox/me",
              "GET /mailbox/session",
              "GET /mailbox/identity",
              "PATCH /mailbox/identity",
              "GET /mailbox/identities"
            ]
          },
          {
            "group": "Messages",
            "pages": [
              "GET /mailbox/messages",
              "POST /mailbox/messages:batch-get",
              "POST /mailbox/messages:batch-update",
              "POST /mailbox/messages:batch-delete",
              "GET /mailbox/messages/count",
              "GET /mailbox/messages/query-changes",
              "GET /mailbox/messages/search-snippets",
              "GET /mailbox/messages/{message_id}",
              "GET /mailbox/messages/{message_id}/body",
              "GET /mailbox/messages/{message_id}/content",
              "PATCH /mailbox/messages/{message_id}",
              "DELETE /mailbox/messages/{message_id}",
              "POST /mailbox/attachments:upload",
              "GET /mailbox/messages/{message_id}/attachments/{attachment_id}",
              "POST /mailbox/messages/send"
            ]
          },
          {
            "group": "Threads",
            "pages": [
              "GET /mailbox/threads",
              "GET /mailbox/threads/{thread_id}",
              "GET /mailbox/threads/{thread_id}/messages",
              "GET /mailbox/threads/{thread_id}/content"
            ]
          },
          {
            "group": "Folders",
            "pages": [
              "GET /mailbox/folders",
              "POST /mailbox/folders",
              "GET /mailbox/folders/changes",
              "GET /mailbox/folders/query-changes",
              "GET /mailbox/folders/{folder_id}",
              "PATCH /mailbox/folders/{folder_id}",
              "DELETE /mailbox/folders/{folder_id}"
            ]
          },
          {
            "group": "Submissions",
            "pages": [
              "GET /mailbox/submissions",
              "GET /mailbox/submissions/changes",
              "GET /mailbox/submissions/{submission_id}"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "GET /mailbox/quotas",
              "GET /mailbox/quotas/changes",
              "GET /mailbox/usage"
            ]
          },
          {
            "group": "Sync",
            "pages": ["GET /mailbox/changes", "GET /mailbox/events"]
          }
        ]
      },
      {
        "tab": "Sending API",
        "openapi": {
          "source": "https://smtp.sendmux.ai/api/v1/openapi.json",
          "directory": "api"
        },
        "groups": [
          {
            "group": "Overview",
            "pages": ["sending-api/introduction", "sending-api/errors"]
          },
          {
            "group": "Emails",
            "pages": ["POST /emails/send", "POST /emails/send/batch"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.sendmux.ai"
        },
        {
          "anchor": "Website",
          "href": "https://sendmux.ai"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg",
    "href": "https://sendmux.ai/docs"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/changelog"
      },
      {
        "label": "Support",
        "href": "mailto:contact@sendmux.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://app.sendmux.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sendmux",
      "github": "https://github.com/sendmux"
    }
  },
  "fonts": {
    "family": "Lato",
    "weight": 400,
    "heading": {
      "family": "Lato",
      "weight": 900
    },
    "body": {
      "family": "Lato",
      "weight": 400
    }
  },
  "description": "The intelligent email layer",
  "seo": {
    "metatags": {
      "canonical": "https://sendmux.ai/docs"
    }
  },
  "appearance": {
    "default": "system"
  },
  "redirects": [
    {
      "source": "/api-reference/webhooks/verify-signatures",
      "destination": "/guides/webhooks-verify-signatures"
    },
    {
      "source": "/api-reference/domains",
      "destination": "/guides/domain-management"
    },
    {
      "source": "/api-reference/webhooks/introduction",
      "destination": "/guides/webhooks-setup"
    },
    {
      "source": "/api-reference",
      "destination": "/api/introduction"
    },
    {
      "source": "/api-reference/:slug*",
      "destination": "/api/:slug*"
    },
    {
      "source": "/api",
      "destination": "/api/introduction"
    }
  ]
}
