{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sendmux",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.sendmux.ai",
          "icon": "gauge"
        },
        {
          "anchor": "Website",
          "href": "https://sendmux.ai",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sendmux.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.sendmux.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sendmux",
      "github": "https://github.com/sendmux"
    }
  },
  "fonts": {
    "family": "Lato",
    "weight": 400,
    "heading": {
      "family": "Lato",
      "weight": 700
    },
    "body": {
      "family": "Lato",
      "weight": 400
    }
  }
}
